# Meteorological Pipeline Environment Variables
PORT=8000
HOST=0.0.0.0

# ERA5 ECMWF Copernicus Data Store Configurations (Optional - Fallback to mock simulation if empty)
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
CDS_API_KEY=your-cds-api-key-here

# India Meteorological Department Credentials (Optional)
IMD_API_KEY=your-imd-api-key-here

# NASA Earthdata Access Credentials (Optional)
EARTHDATA_USERNAME=your-username
EARTHDATA_PASSWORD=your-password

# AI weather summary. Gemini is used unless SUMMARY_PROVIDER is changed to claude
# or a Claude key is saved through the application settings.
SUMMARY_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Optional Anthropic Claude override
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
